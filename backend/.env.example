# Server
PORT=5000

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Ollama (local LLM)
# Default assumes Ollama is running locally on port 11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# NCBI / PubMed (required for production — prevents rate limiting)
# NCBI_EMAIL is mandatory for production requests per NCBI policy
# NCBI_API_KEY is optional but raises rate limit from 3 req/s to 10 req/s
# Get a free API key at: https://www.ncbi.nlm.nih.gov/account/
NCBI_EMAIL=your_email@example.com
NCBI_API_KEY=your_ncbi_api_key_here

# Groq (Tier 2 LLM — free, fast, OpenAI-compatible)
# Get a free API key at: https://console.groq.com
# The app tries Ollama first, then Groq, then HuggingFace, then a static response
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama3-8b-8192
