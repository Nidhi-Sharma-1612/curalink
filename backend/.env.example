# Server
PORT=5000

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Ollama (local LLM)
# Default assumes Ollama is running locally on port 11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Hugging Face Inference API (production fallback when Ollama is unavailable)
# Get your free token at: https://huggingface.co/settings/tokens
# The app tries Ollama first, then falls back to HuggingFace, then to a static response
HUGGINGFACE_TOKEN=hf_your_token_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
